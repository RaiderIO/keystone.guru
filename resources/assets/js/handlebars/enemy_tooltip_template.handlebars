<div class="enemy_tooltip">
    <div class="row g-0">
        <div class="col fw-bold">
            {{name}}
        </div>
    </div>
    {{#each info}}
        <div class="row g-0">
            <div class="col-7 pe-1">
                {{key}}:
            </div>
            <div class="col-5">
                {{#ifCond value '===' 1}}
                    <span class="text-success"><i class="fas fa-check-circle"></i></span>
                {{else}}
                    {{#ifCond value '===' 0}}
                        <span class="text-danger"><i class="fas fa-times-circle"></i></span>
                    {{else}}
                        {{{value}}}
                    {{/ifCond}}
                {{/ifCond}}
            </div>
        </div>
    {{/each}}
    <div class="row g-0 mt-1">
        <div class="col-12 italic">
            {{right_click_to_open_details_label}}
        </div>
    </div>
    {{#if show_raid_marker_shortcut}}
        <div class="row g-0">
            <div class="col-12 italic">
                {{shift_right_click_to_assign_raid_marker_label}}
            </div>
        </div>
    {{/if}}
</div>
