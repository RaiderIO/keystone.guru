<div class="col-auto" data-toggle="tooltip" title="{{name}} (+{{enemy_forces}}/+{{enemy_forces_percent}}%)">
    <div class="row no-gutters">
        <div class="col">
            <img src="{{enemy_portrait_url}}"
                 style="height: 37px; width: 37px; border-radius: 30px; border: 2px solid {{pull_color}}"/>
            {{#if state_overlay}}
                <div class="text-center {{state_overlay.colorClass}}" style="position: relative; margin-top: -37px;">
                    <span style="font-size: 24px; background-color: black; border-radius: 100px">
                        <i class="fa {{state_overlay.iconClass}}"></i>
                    </span>
                </div>
            {{/if}}
            <div class="text-center text-white"
                 style="position: relative; margin-top: -23px; text-shadow: black 1px 1px;">
                {{count}}x
            </div>
        </div>
    </div>
</div>
