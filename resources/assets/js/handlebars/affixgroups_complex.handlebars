<span class="target_tooltip" data-bs-toggle="tooltip" data-bs-html="true">
    {{count}} {{selected_label}}
</span>
<div class="affix_list_row_container">
    {{#affixgroups}}
        <div class="row affix_list_row g-0" style="width: 200px">
            {{#affixes}}
                <div class="affix_row col-md">
                    <div class="select_icon affix_icon_{{class}} {{#unless @last}}me-2{{/unless}}"
                         style="height: 24px;">
                        &nbsp;
                    </div>
                </div>
            {{/affixes}}
            {{#if seasonal_index}}
            <div class="affix_row col-md">
                <div class="select_icon" style="height: 24px; max-width: 100% !important;">
                        {{seasonal_index}}
                </div>
            </div>
            {{/if}}
        </div>
    {{/affixgroups}}
</div>
