        {"name": "dungeon_route_title", "value": "My Test Route"},
        {"name": "dungeon_route_level", "value": "{{key_level_min}};{{key_level_max}}"},
        {"name": "route_select_affixes[]", "value": "{{affix_group_id}}"},
        {"name": "faction_id", "value": "{{faction_id}}"},
        {"name": "class[]", "value": "{{class_id}}"},
        {"name": "class[]", "value": "0"},
        {"name": "class[]", "value": "0"},
        {"name": "class[]", "value": "0"},
        {"name": "class[]", "value": "0"},
        {"name": "specialization[]", "value": "{{specialization_id}}"},
        {"name": "specialization[]", "value": "0"},
        {"name": "specialization[]", "value": "0"},
        {"name": "specialization[]", "value": "0"},
        {"name": "specialization[]", "value": "0"},
        {"name": "race[]", "value": "{{race_id}}"},
        {"name": "race[]", "value": "0"},
        {"name": "race[]", "value": "0"},
        {"name": "race[]", "value": "0"},
        {"name": "race[]", "value": "0"}
    ]
}
