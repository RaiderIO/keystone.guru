{
    "description": "Retail: user fills in party member #1's faction, class, specialization and race via Tom Select. Party members #2-5 stay at their default '0' (unset) value.",
    "endpoint": "dungeonroute.savenew",
    "gameVersion": "retail",
    "auth": true,
    "fields": [
        {"name": "dungeon_id", "value": "{{dungeon_id}}"},
