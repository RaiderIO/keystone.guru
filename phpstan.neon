includes:
    - vendor/larastan/larastan/extension.neon

parameters:
    paths:
        - app/
        - database/
        - resources/views/
        - routes/
        - tests/

    # Level 9 is the highest level
    level: 3

    # I have no idea why this is necessary
    scanDirectories:
        - vendor/paquettg/php-html-parser/src

    # Prevent hogging of all resources
    # https://phpstan.org/config-reference#parallel-processing
    parallel:
        jobSize: 20
        maximumNumberOfProcesses: 4
        minimumNumberOfJobsPerProcess: 2

    excludePaths:
        # '#Keyword continue used outside of a loop or a switch statement#'
        - resources/views/admin/tools/mdt/dungeonmappingversionaccuracy.blade.php
        # Legacy migrations ran against old framework API (Blueprint::double with column/total args removed in L10+)
        - database/migrations_legacy/
        # Legacy Laravel 5-style factory file, superseded by class-based factories
        - database/factories/ModelFactory.php

    ignoreErrors:
        # Blade templates use ??= as a pattern to set optional variable defaults
        - identifier: nullCoalesce.variable
          path: resources/views
        # Blade templates use isset() for optional variables
        - identifier: isset.variable
          path: resources/views
        # Blade foreach loop variables and view-composer-provided variables
        - identifier: variable.undefined
          path: resources/views
        # Blade templates captured variables that phpstan thinks are unused
        - identifier: closure.unusedUse
          path: resources/views
        # TrayLabs InfluxDB facade — writePoints() is a magic method not declared in the facade stub
        # reportUnmatched: false — errors appear in CI (fresh vendor) but not locally (cached reflection)
        - identifier: staticMethod.notFound
          reportUnmatched: false
          paths:
            - app/Console/Commands/Traits/SavesToInfluxDB.php
            - app/Console/Commands/Scheduler/Telemetry/Telemetry.php

#    checkMissingIterableValueType: false
